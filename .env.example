DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# OpenAI API Key (required for AI summaries)
AI_INTEGRATIONS_OPENAI_API_KEY=your-openai-api-key-here

# Optional: Custom OpenAI base URL
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1/

# Tavily API Key (required for web search enrichment)
# Get your API key from https://tavily.com
# Pricing: 1,000 free searches/month, then $0.008/search
# Used to find real-time company headquarters and founder residence information
TAVILY_API_KEY=your-tavily-api-key-here

# Optional: ScrapingBee API key for web scraping
# SCRAPINGBEE_API_KEY=your-scrapingbee-api-key

# Optional: SendGrid API key for email notifications (deprecated - use Telegram)
# SENDGRID_API_KEY=your-sendgrid-api-key

# Optional: Telegram bot token for notifications
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Optional: Public server URL for Telegram webhook mode
# When set alongside TELEGRAM_BOT_TOKEN, the bot uses webhook mode (Telegram pushes updates).
# When omitted, the bot falls back to polling mode (the bot pulls updates).
# Must be a publicly accessible HTTPS URL (e.g., https://your-domain.com)
# SERVER_URL=https://your-domain.com

# Server port (defaults to 5000)
PORT=5000
